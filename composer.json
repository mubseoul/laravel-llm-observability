{
    "name": "mubseoul/laravel-llm-observability",
    "description": "Laravel-native observability and cost tracking toolkit for LLM calls (OpenAI, Claude, etc.)",
    "keywords": [
        "laravel",
        "llm",
        "observability",
        "openai",
        "claude",
        "anthropic",
        "ai",
        "cost-tracking",
        "monitoring"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Mubseoul",
            "email": "mubseoul@users.noreply.github.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^10.0|^11.0",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/database": "^10.0|^11.0",
        "illuminate/queue": "^10.0|^11.0",
        "illuminate/notifications": "^10.0|^11.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "pestphp/pest": "^2.34",
        "pestphp/pest-plugin-laravel": "^2.3",
        "phpstan/phpstan": "^1.10",
        "laravel/pint": "^1.13",
        "filament/filament": "^3.2"
    },
    "suggest": {
        "filament/filament": "Required for the admin dashboard UI (^3.2)"
    },
    "autoload": {
        "psr-4": {
            "Mubseoul\\LLMObservability\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mubseoul\\LLMObservability\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mubseoul\\LLMObservability\\LLMObservabilityServiceProvider"
            ],
            "aliases": {
                "LLM": "Mubseoul\\LLMObservability\\Facades\\LLM"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
